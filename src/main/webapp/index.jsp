<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8"%>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MemoryVault</title>

    <link rel="stylesheet" href="css/style.css">
</head>

<body>

<header class="home-header">

    <div class="home-container nav-wrapper">

        <h1 class="logo-text">
            &#10024; Memory<span>Vault</span>
        </h1>

        <nav>
            <ul class="nav-menu">
                <li><a href="index.jsp">Home</a></li>
                <li><a href="login.jsp">Login</a></li>
                <li><a href="register.jsp" class="nav-btn">Register</a></li>
            </ul>
        </nav>

    </div>

</header>

<section class="home-hero">

    <div class="home-container hero-wrapper">

        <div class="hero-text">

            <h2>
                Your Future Self Awaits;
            </h2>

            <p>
                Preserve your memories, thoughts, dreams, secret letters,
                photos, voice notes and videos. Lock them away today and
                let time be your key.
            </p>

            <div class="hero-buttons">

                <a href="register.jsp" class="main-btn">
                    Get Started
                </a>

                <a href="login.jsp" class="outline-btn">
                    I already have an account
                </a>

            </div>

        </div>

        <div class="hero-card">

            <div class="capsule-icon">
                &#128140;
            </div>

            <h3>Dear Future Me...</h3>

            <p>
                Open this when the time is right.
            </p>

        </div>

    </div>

</section>

<section class="features">

    <div class="home-container">

        <h2 class="section-title">
            What can you save?
        </h2>

        <div class="feature-grid">

            <div class="feature-item">

                <div class="emoji">
                    &#128140;
                </div>

                <h3>Write Letters</h3>

                <p>
                    Write heartfelt letters to your future self.
                </p>

            </div>

            <div class="feature-item">

                <div class="emoji">
                    &#128247;
                </div>

                <h3>Share Moments</h3>

                <p>
                    Upload images that capture your special memories.
                </p>

            </div>

            <div class="feature-item">

                <div class="emoji">
                    &#127909;
                </div>

                <h3>Record Videos</h3>

                <p>
                    Save video messages for the future you to discover.
                </p>

            </div>

            <div class="feature-item">

                <div class="emoji">
                    &#127897;
                </div>

                <h3>Voice Notes</h3>

                <p>
                    Capture your voice, emotions and tiny life updates.
                </p>

            </div>

        </div>

    </div>

</section>

<section class="how-it-works">

    <div class="home-container">

        <h2 class="section-title">
            How it works
        </h2>

        <div class="steps-grid">

            <div class="step-card">

                <span>01</span>

                <h3>Create Capsule</h3>

                <p>
                    Add a message, image, audio or video memory.
                </p>

            </div>

            <div class="step-card">

                <span>02</span>

                <h3>Set Unlock Date</h3>

                <p>
                    Choose when your capsule should open.
                </p>

            </div>

            <div class="step-card">

                <span>03</span>

                <h3>Get Notified</h3>
                    <p>Receive an in-app popup notification when your capsule is ready to unlock.</p>

            </div>

        </div>

    </div>

</section>

<footer class="home-footer">

    <p>
        Made with &#127807; for future memories — MemoryVault
    </p>

</footer>

</body>
</html>